{
  "name": "omuraisu-library-c",
  "version": "1.0.0",
  "description": "Robot development C++ library for chassis control, coordinate systems, PID, and DJI motor control",
  "keywords": [
    "robotics",
    "mecanum",
    "pid",
    "dji",
    "c620",
    "m3508",
    "coordinate",
    "controller"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omuct-robotclub/omuraisu-library-c.git"
  },
  "authors": [
    {
      "name": "BIT"
    }
  ],
  "license": "MIT",
  "frameworks": ["mbed", "*"],
  "platforms": "*",
  "build": {
    "srcDir": "src",
    "includeDir": "include",
    "flags": ["-I include/omuraisu/cpp", "-I include/omuraisu/c"]
  },
  "headers": [
    "include/omuraisu/cpp/coordinate/*.hpp",
    "include/omuraisu/cpp/controller/*.hpp",
    "include/omuraisu/cpp/dji/*.hpp",
    "include/omuraisu/cpp/pid/*.hpp",
    "include/omuraisu/cpp/can/*.hpp"
  ]
}
